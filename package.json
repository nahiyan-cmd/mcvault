# Azure App Registration values
MS_CLIENT_ID=your-client-id-here
MS_CLIENT_SECRET=your-client-secret-here

# Must EXACTLY match the redirect URI set in Azure (App registrations > Authentication)
MS_REDIRECT_URI=https://yourdomain.com/api/auth/callback

# Random long random string used to sign session cookies
SESSION_SECRET=change-this-to-a-long-random-string

# Port the server runs on (most hosts override this automatically)
PORT=3000
